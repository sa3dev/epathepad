# Postgres
DATABASE_URL=postgres://epatehpad:epatehpad@localhost:5434/epatehpad

# Auth.js — generate with `npx auth secret`
AUTH_SECRET=
# Must match the public domain exactly in production (e.g. https://epatehpad.fr)
AUTH_URL=http://localhost:3000

# Transactional email via Resend (magic link + password reset). Prod only —
# dev logs the email content to the console instead.
RESEND_API_KEY=
# Must be on a domain verified in Resend, or use the onboarding@resend.dev test sender.
EMAIL_FROM="Épat'Ehpad <onboarding@resend.dev>"

# S3-compatible storage (Cloudflare R2 or equivalent) for artist photos/videos
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
# Public base URL used to build media URLs served to the browser (build-time in Docker)
S3_PUBLIC_BASE_URL=
NEXT_PUBLIC_MEDIA_HOSTNAME=
